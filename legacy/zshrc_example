
# token to enable mcp web search via github copilot
export GHE_MCP_TOKEN="SECRET_A"
export GITHUB_MCP_TOKEN="SECRET_B"

# as we need to pass credentials from this env to lima env this vars tells lima which should be transferred to keep lima env clean
export export LIMA_SHELLENV_BLOCK="*"
export LIMA_SHELLENV_ALLOW="GHE_MCP_TOKEN, GITHUB_MCP_TOKEN"

# Creates and starts a new Pi Sandbox for the current project directory
pi-create() {
    local script_path="$HOME/.pi/create_pi_vm.sh"

    if [ ! -f "$script_path" ]; then
        echo "❌ Error: Startup script not found at $script_path"
        return 1
    fi

    echo "🏗️  Initializing project: $(basename "$PWD")"

    # Execute the script from the current directory
    bash "$script_path"
}

# Enters the Pi Coding Agent VM for the current project directory.
# Automatically starts the VM if it is stopped.
pi-enter() {
    local project_name=$(basename "$PWD")
    
    # 1. Check if the VM exists and get its exact status
    local vm_status=$(limactl ls -f '{{.Status}}' "$project_name" 2>/dev/null)
    
    # 2. Safety check: Does the VM even exist?
    if [ -z "$vm_status" ]; then
        echo "❌ Error: Sandbox '$project_name' does not exist yet."
        echo "👉 Please run 'pi-start' first to build it."
        return 1
    fi
    
    # 3. State check: If it exists but isn't running, start it
    if [ "$vm_status" != "Running" ]; then
        echo "⏳ Sandbox '$project_name' is currently $vm_status. Waking it up..."
        # This will safely block until the VM is fully booted and SSH is ready
        limactl start "$project_name"
    fi
    
    # 4. Enter the sandbox
    echo "🚪 Entering Sandbox: $project_name"
    limactl shell --preserve-env --workdir=/app "$project_name" 
}

# Stops and completely removes the Pi Coding Agent VM for the current project.
# Includes a safety prompt to prevent accidental deletions.
pi-delete() {
    local project_name=$(basename "$PWD")
    
    # 1. Check if the VM exists
    local vm_status=$(limactl ls -f '{{.Status}}' "$project_name" 2>/dev/null)
    
    if [ -z "$vm_status" ]; then
        echo "❌ Error: Sandbox '$project_name' does not exist."
        return 1
    fi
    
    # 2. Safety Confirmation Prompt
    echo -n "⚠️  Are you sure you want to completely delete the sandbox '$project_name'? [y/N] "
    read response
    
    # Check if the response is anything OTHER than 'y' or 'Y'
    if [ "$response" != "y" ] && [ "$response" != "Y" ]; then
        echo "🛑 Deletion canceled."
        return 0
    fi
    
    # 3. Stop the VM if it is running (Using single '=' for Zsh compatibility)
    if [ "$vm_status" = "Running" ]; then
        echo "🛑 Stopping sandbox '$project_name'..."
        limactl stop "$project_name"
    fi
    
    # 4. Delete the VM
    echo "🗑️  Deleting sandbox '$project_name'..."
    limactl delete "$project_name"
    
    echo "✅ Sandbox '$project_name' has been successfully removed."
}