{
  "mcpServers": {
    "ghe": {
      "url": "https://copilot-api.techem.ghe.com/mcp/readonly",
      "auth": "bearer",
      "bearerTokenEnv": "GHE_MCP_TOKEN",
      "headers": {
        "X-MCP-Toolsets": "web_search"
      }
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/readonly",
      "auth": "bearer",
      "bearerTokenEnv": "GITHUB_MCP_TOKEN",
      "headers": {
        "X-MCP-Toolsets": "discussions,gists,issues,pull_requests,repos"
      }
    }
  }
}