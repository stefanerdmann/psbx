vmType: vz
mountType: virtiofs
user:
  name: pi
images:
  - location: https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-arm64.img
    arch: aarch64
cpus: {{vm.cpus}}
memory: {{vm.memory}}
disk: {{vm.disk}}
mounts:
  - location: {{pi.configDir}}
    mountPoint: /mnt/pi-host-config
    writable: false
  - location: {{projectDir}}
    mountPoint: /app
    writable: true
{{#if cert}}
  - location: {{cert.dir}}
    mountPoint: /mnt/host-cert-dir
    writable: false
{{/if}}
provision:
  - mode: system
    script: |
{{{systemProvision}}}
  - mode: user
    script: |
{{{userProvision}}}
